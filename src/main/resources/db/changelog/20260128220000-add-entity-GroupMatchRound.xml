<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
      http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd"
>
    <changeSet id="20260128220000-01" author="hunglc">
        <createTable tableName="t_group_matches_rounds">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="fk_group_match_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="fk_round_id" type="bigint">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="20260128220000-02" author="hunglc">
        <addForeignKeyConstraint baseTableName="t_group_matches_rounds"
                                 baseColumnNames="fk_group_match_id"
                                 constraintName="fk_tt_group_matches_rounds_group_match_id"
                                 referencedTableName="t_group_matches"
                                 referencedColumnNames="id"/>
    </changeSet>
    <changeSet id="20260128220000-03" author="hunglc">
        <addForeignKeyConstraint baseTableName="t_group_matches_rounds"
                                 baseColumnNames="fk_round_id"
                                 constraintName="fk_t_group_matches_rounds_round_id"
                                 referencedTableName="t_rounds"
                                 referencedColumnNames="id"/>
    </changeSet>
</databaseChangeLog>