<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
      http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd"
>
    <changeSet id="20260128210000-01" author="hunglc">
        <createTable tableName="t_rounds">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="fk_tour_id" type="bigint">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="20260128210000-02" author="hunglc">
        <addForeignKeyConstraint baseTableName="t_rounds"
                                 baseColumnNames="fk_tour_id"
                                 constraintName="fk_t_rounds_tour_id"
                                 referencedTableName="t_tours"
                                 referencedColumnNames="id"/>
    </changeSet>
    <changeSet id="20260128210000-03" author="hunglc">
        <addForeignKeyConstraint baseTableName="t_matches"
                                 baseColumnNames="fk_round_id"
                                 constraintName="fk_t_matches_round_id"
                                 referencedTableName="t_rounds"
                                 referencedColumnNames="id"/>
    </changeSet>
    <changeSet id="20260128210000-04" author="hunglc">
        <addColumn tableName="t_rounds">
            <column name="type" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>
    <changeSet id="20260128210000-05" author="hunglc">
        <createIndex tableName="t_rounds" indexName="idx_t_rounds_fk_tour_id">
            <column name="fk_tour_id" type="bigint"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>